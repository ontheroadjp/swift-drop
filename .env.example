# Database provider selector:
# - sqlite: local file DB (default)
# - turso: Turso/libSQL
DB_PROVIDER=sqlite

# Public base URL used in upload response.
# Example: https://your-app.vercel.app
APP_BASE_URL=

# Trust x-forwarded-for only when behind trusted reverse proxy.
TRUST_PROXY=false

# Turso settings (required only when DB_PROVIDER=turso)
# TURSO_DATABASE_URL=libsql://<your-db>.turso.io
# TURSO_AUTH_TOKEN=<your-turso-auth-token>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
